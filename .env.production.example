POSTGRES_DB="lotiva"
POSTGRES_USER="lotiva_user"
POSTGRES_PASSWORD="replace-with-a-strong-database-password"

NEXTAUTH_URL="https://app.seudominio.com"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="https://app.seudominio.com"
AUTH_SECRET="replace-with-a-long-random-secret"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-smtp-app-password"
SMTP_FROM="Lotiva <your-email@gmail.com>"

APP_PORT="3000"

# Generate once with `openssl rand -base64 32` and keep it stable.
PAYMENT_CREDENTIALS_KEY="replace-with-a-base64-32-byte-key"
