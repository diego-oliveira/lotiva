// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  logo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  developments Development[]
}

model Development {
  id        String   @id @default(uuid())
  name      String
  logo      String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company            @relation(fields: [companyId], references: [id])
  blocks       Block[]
  memberships  DevelopmentUser[]
}

model User {
  id            String           @id @default(uuid())
  name          String
  cpf           String           @unique
  address       String
  birthDate     DateTime
  rg            String
  email         String           @unique
  profession    String
  birthplace    String
  maritalStatus String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  reservations Reservation[]
  sales        Sale[]
  memberships  DevelopmentUser[]
}

model Role {
  id          String               @id @default(uuid())
  name        String               @unique
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  assignments DevelopmentUserRole[]
}

model DevelopmentUser {
  id           String               @id @default(uuid())
  developmentId String
  userId       String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  development  Development          @relation(fields: [developmentId], references: [id])
  user         User                 @relation(fields: [userId], references: [id])
  roles        DevelopmentUserRole[]

  @@unique([developmentId, userId])
}

model DevelopmentUserRole {
  id               String         @id @default(uuid())
  developmentUserId String
  roleId           String
  createdAt        DateTime       @default(now())

  developmentUser  DevelopmentUser @relation(fields: [developmentUserId], references: [id])
  role             Role            @relation(fields: [roleId], references: [id])

  @@unique([developmentUserId, roleId])
}

model Block {
  id           String      @id @default(uuid())
  identifier   String
  developmentId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  development Development? @relation(fields: [developmentId], references: [id])
  lots        Lot[]
}

model Lot {
  id         String   @id @default(uuid())
  identifier String
  blockId    String
  front      Float
  back       Float
  leftSide   Float
  rightSide  Float
  totalArea  Float
  price      Float
  status     String   @default("available")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  block        Block    @relation(fields: [blockId], references: [id])
  reservations Reservation[]
  sale         Sale?    // 👈 one-to-one back relation
}

model Reservation {
  id         String   @id @default(uuid())
  userId     String
  lotId      String
  proposal   String
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id])
  lot        Lot    @relation(fields: [lotId], references: [id])
  sale       Sale?  // 👈 if only one sale can reference a reservation

  @@unique([lotId]) // 👈 prevents multiple reservations for the same lot
}

model Sale {
  id                String     @id @default(uuid())
  userId            String
  lotId             String     @unique
  reservationId     String?    @unique
  installmentCount  Int
  installmentValue  Float
  downPayment       Float
  annualAdjustment  Boolean    @default(true)
  totalValue        Float
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  lot         Lot          @relation(fields: [lotId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  contract    Contract?
}

model Contract {
  id           String    @id @default(uuid())
  saleId       String    @unique
  contractNumber String  @unique
  content      String    @db.Text
  emailSent    Boolean   @default(false)
  emailSentAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sale Sale @relation(fields: [saleId], references: [id])
}
