// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                String   @id @default(uuid())
  name              String
  logo              String
  legalName         String   @default("")
  document          String   @default("")
  stateRegistration String   @default("")
  address           String   @default("")
  city              String   @default("")
  state             String   @default("")
  zipCode           String   @default("")
  phone             String   @default("")
  email             String   @default("")
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy          User? @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  developments      Development[]
  documentTemplates DocumentTemplate[]
  documentVariables DocumentVariable[]
  paymentConnections PaymentProviderConnection[]
  financialAuditLogs FinancialAuditLog[]
  memberships      CompanyUser[]
}

model Development {
  id        String   @id @default(uuid())
  name      String
  logo      String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company            Company                      @relation(fields: [companyId], references: [id])
  blocks             Block[]
  memberships        DevelopmentUser[]
  settings           DevelopmentSettings?
  contractSettings   DevelopmentContractSettings?
  documentTemplateId String?
  documentTemplate   DocumentTemplate?            @relation(fields: [documentTemplateId], references: [id], onDelete: SetNull)
  documentValues     DevelopmentDocumentValue[]

  @@index([documentTemplateId])
  @@index([deletedAt])
}

model DevelopmentSettings {
  id                       String   @id @default(uuid())
  developmentId            String   @unique
  reservationValidityDays  Int      @default(7)
  defaultInterestRate      Float    @default(0)
  interestCalculation      String   @default("none")
  correctionIndex          String   @default("none")
  correctionFrequency      String   @default("monthly")
  minDownPaymentPercentage Float    @default(10)
  maxInstallments          Int      @default(120)
  paymentMethods           String   @default("cash,installments")
  allowCustomTerms         Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
}

model DevelopmentContractSettings {
  id                     String   @id @default(uuid())
  developmentId          String   @unique
  sellerName             String   @default("")
  sellerDocument         String   @default("")
  sellerAddress          String   @default("")
  sellerRepresentatives  String   @default("")
  propertyDescription    String   @default("")
  acquisitionDescription String   @default("")
  paymentInstructions    String   @default("")
  jurisdiction           String   @default("")
  additionalClauses      String   @default("") @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  cpf           String?   @unique
  address       String?
  birthDate     DateTime?
  rg            String?
  emailVerified DateTime?
  image         String?
  profession    String?
  birthplace    String?
  maritalStatus String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reservations        Reservation[]
  createdReservations Reservation[]             @relation("ReservationCreator")
  sales               Sale[]
  createdSales        Sale[]                    @relation("SaleCreator")
  proposals           Proposal[]                @relation("ProposalBuyer")
  createdProposals    Proposal[]                @relation("ProposalCreator")
  reviewedProposals   Proposal[]                @relation("ProposalReviewer")
  notifications       Notification[]
  memberships         DevelopmentUser[]
  companyMemberships  CompanyUser[]
  createdCompanies    Company[]                  @relation("CompanyCreator")
  accounts            Account[]
  sessions            Session[]
  lotEvents           LotEvent[]
  documentTemplates   DocumentTemplate[]
  templateVersions    DocumentTemplateVersion[]
  externalCustomers   ExternalCustomer[]
  adjustmentReviewsCreated  AdjustmentReview[] @relation("AdjustmentReviewCreator")
  adjustmentReviewsReviewed AdjustmentReview[] @relation("AdjustmentReviewReviewer")
  financialAuditLogs        FinancialAuditLog[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments DevelopmentUserRole[]
  companyAssignments CompanyUserRole[]
}

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles   CompanyUserRole[]

  @@unique([companyId, userId])
}

model CompanyUserRole {
  id            String   @id @default(uuid())
  companyUserId String
  roleId        String
  createdAt     DateTime @default(now())

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  role        Role        @relation(fields: [roleId], references: [id])

  @@unique([companyUserId, roleId])
}

model DevelopmentUser {
  id            String   @id @default(uuid())
  developmentId String
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development Development           @relation(fields: [developmentId], references: [id])
  user        User                  @relation(fields: [userId], references: [id])
  roles       DevelopmentUserRole[]

  @@unique([developmentId, userId])
}

model DevelopmentUserRole {
  id                String   @id @default(uuid())
  developmentUserId String
  roleId            String
  createdAt         DateTime @default(now())

  developmentUser DevelopmentUser @relation(fields: [developmentUserId], references: [id])
  role            Role            @relation(fields: [roleId], references: [id])

  @@unique([developmentUserId, roleId])
}

model Block {
  id            String   @id @default(uuid())
  identifier    String
  developmentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development Development? @relation(fields: [developmentId], references: [id])
  lots        Lot[]
}

model Lot {
  id         String   @id @default(uuid())
  identifier String
  blockId    String
  front      Float
  back       Float
  leftSide   Float
  rightSide  Float
  totalArea  Float
  price      Decimal  @db.Decimal(15, 2)
  status     String   @default("available")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  block        Block         @relation(fields: [blockId], references: [id])
  reservations Reservation[]
  proposals    Proposal[]
  sale         Sale? // 👈 one-to-one back relation
  events       LotEvent[]
}

model Reservation {
  id          String    @id @default(uuid())
  userId      String
  createdById String?
  lotId       String
  proposal    String
  status      String
  expiresAt   DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  createdBy User?      @relation("ReservationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lot       Lot        @relation(fields: [lotId], references: [id])
  proposals Proposal[]
  sale      Sale? // 👈 if only one sale can reference a reservation

  @@unique([lotId]) // 👈 prevents multiple reservations for the same lot
  @@index([createdById])
}

model Proposal {
  id                  String    @id @default(uuid())
  userId              String
  createdById         String
  reviewedById        String?
  lotId               String
  reservationId       String?
  status              String    @default("draft")
  exceptionReasons    String?
  reviewedAt          DateTime?
  rejectionReason     String?
  salePrice           Decimal   @db.Decimal(15, 2)
  downPayment         Decimal   @db.Decimal(15, 2)
  installmentCount    Int
  installmentValue    Decimal   @db.Decimal(15, 2)
  balance             Decimal   @db.Decimal(15, 2)
  totalValue          Decimal   @db.Decimal(15, 2)
  interestRate        Float     @default(0)
  interestCalculation String    @default("none")
  correctionIndex     String    @default("none")
  correctionFrequency String    @default("monthly")
  firstDueDate        DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user        User         @relation("ProposalBuyer", fields: [userId], references: [id])
  createdBy   User         @relation("ProposalCreator", fields: [createdById], references: [id])
  reviewedBy  User?        @relation("ProposalReviewer", fields: [reviewedById], references: [id])
  lot         Lot          @relation(fields: [lotId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  sale        Sale?

  @@index([createdById, status])
  @@index([reviewedById])
  @@index([status, createdAt])
}

model Sale {
  id               String    @id @default(uuid())
  userId           String
  createdById      String?
  lotId            String    @unique
  reservationId    String?   @unique
  proposalId       String?   @unique
  installmentCount Int
  installmentValue Decimal   @db.Decimal(15, 2)
  downPayment      Decimal   @db.Decimal(15, 2)
  firstDueDate     DateTime?
  annualAdjustment Boolean   @default(true)
  totalValue       Decimal   @db.Decimal(15, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  createdBy   User?        @relation("SaleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lot         Lot          @relation(fields: [lotId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  proposal    Proposal?    @relation(fields: [proposalId], references: [id])
  contract    Contract?
  receivables Receivable[]
  billingCycles BillingCycle[]
  adjustmentReviews AdjustmentReview[]

  @@index([createdById, createdAt])
}

model Contract {
  id                        String    @id @default(uuid())
  saleId                    String    @unique
  contractNumber            String    @unique
  docxPath                  String
  pdfPath                   String?
  status                    String    @default("generated")
  version                   Int       @default(1)
  lastRegenerationReason    String?
  emailSent                 Boolean   @default(false)
  emailSentAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  documentTemplateVersionId String?

  sale                    Sale                     @relation(fields: [saleId], references: [id])
  documentTemplateVersion DocumentTemplateVersion? @relation(fields: [documentTemplateVersionId], references: [id], onDelete: SetNull)
  events                  ContractEvent[]

  @@index([documentTemplateVersionId])
}

model DocumentTemplate {
  id          String   @id @default(uuid())
  companyId   String
  createdById String
  name        String
  type        String   @default("contract")
  purpose     String   @default("sale_contract")
  description String?
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company      Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User                      @relation(fields: [createdById], references: [id])
  versions     DocumentTemplateVersion[]
  developments Development[]

  @@index([companyId, type, purpose, status])
}

model DocumentTemplateVersion {
  id          String    @id @default(uuid())
  templateId  String
  createdById String
  version     Int
  status      String    @default("draft")
  filePath    String
  fileName    String
  fileHash    String
  variables   Json
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  template  DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy User             @relation(fields: [createdById], references: [id])
  contracts Contract[]

  @@unique([templateId, version])
  @@index([templateId, status, version])
}

model DocumentVariable {
  id           String   @id @default(uuid())
  companyId    String
  key          String
  label        String
  type         String   @default("text")
  required     Boolean  @default(false)
  defaultValue String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  values  DevelopmentDocumentValue[]

  @@unique([companyId, key])
  @@index([companyId])
}

model DevelopmentDocumentValue {
  id            String   @id @default(uuid())
  developmentId String
  variableId    String
  value         String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  development Development      @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  variable    DocumentVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)

  @@unique([developmentId, variableId])
  @@index([variableId])
}

model ContractEvent {
  id          String   @id @default(uuid())
  contractId  String
  userId      String?
  type        String
  title       String
  description String?
  createdAt   DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@index([type])
}

model Receivable {
  id         String    @id @default(uuid())
  saleId     String
  kind       String    @default("installment")
  sequence   Int
  dueDate    DateTime
  amount     Decimal   @db.Decimal(15, 2)
  paidAmount Decimal   @default(0) @db.Decimal(15, 2)
  balance    Decimal   @db.Decimal(15, 2)
  status     String    @default("pending")
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sale            Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  externalCharges ExternalCharge[]
  adjustmentItems AdjustmentReviewItem[]

  @@unique([saleId, kind, sequence])
  @@index([dueDate])
  @@index([status])
}

model PaymentProviderConnection {
  id                   String   @id @default(uuid())
  companyId            String
  provider             String
  environment          String   @default("sandbox")
  status               String   @default("inactive")
  credentialCiphertext String?  @db.Text
  credentialHint       String?
  lastValidatedAt      DateTime?
  webhookId             String?
  webhookUrl            String?
  webhookStatus         String?  @default("not_configured")
  webhookAuthCiphertext String?  @db.Text
  webhookAuthHint       String?
  lastWebhookAt         DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  externalCustomers ExternalCustomer[]
  externalCharges   ExternalCharge[]
  webhookEvents     PaymentWebhookEvent[]
  billingCycles     BillingCycle[]
  reconciliationRuns ReconciliationRun[]
  adjustmentReviews  AdjustmentReview[]

  @@unique([companyId, provider, environment])
  @@index([companyId, status])
}

model ExternalCustomer {
  id                   String   @id @default(uuid())
  connectionId         String
  userId               String
  providerCustomerId   String
  externalReference    String
  status               String   @default("active")
  lastSynchronizedAt   DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  connection PaymentProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectionId, userId])
  @@unique([connectionId, providerCustomerId])
  @@unique([connectionId, externalReference])
}

model BillingCycle {
  id             String    @id @default(uuid())
  connectionId   String
  saleId         String
  cycleNumber    Int
  startSequence  Int
  endSequence    Int
  status         String    @default("draft")
  issuedAt       DateTime?
  adjustmentReviewId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  connection      PaymentProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  sale            Sale                      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  externalCharges ExternalCharge[]
  adjustmentReview AdjustmentReview?         @relation(fields: [adjustmentReviewId], references: [id], onDelete: SetNull)

  @@unique([connectionId, saleId, cycleNumber])
  @@index([connectionId, status])
  @@index([adjustmentReviewId])
}

model ExternalCharge {
  id                    String    @id @default(uuid())
  connectionId          String
  billingCycleId        String?
  receivableId          String
  providerChargeId      String
  externalReference     String
  version               Int       @default(1)
  billingType           String
  status                String
  amount                Decimal   @db.Decimal(15, 2)
  dueDate               DateTime
  invoiceUrl             String?
  bankSlipUrl            String?
  pixPayload             String?   @db.Text
  pixEncodedImage        String?   @db.Text
  providerPayload        Json?
  grossPaidAmount        Decimal?  @db.Decimal(15, 2)
  netPaidAmount          Decimal?  @db.Decimal(15, 2)
  feeAmount              Decimal?  @db.Decimal(15, 2)
  providerPaymentDate    DateTime?
  providerCreditDate     DateTime?
  lastEventAt            DateTime?
  cancelledAt            DateTime?
  cancellationReason     String?   @db.Text
  cancelledById          String?
  lastSynchronizedAt     DateTime  @default(now())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  connection   PaymentProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  billingCycle BillingCycle?             @relation(fields: [billingCycleId], references: [id], onDelete: SetNull)
  receivable   Receivable                @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@unique([connectionId, providerChargeId])
  @@unique([connectionId, externalReference])
  @@index([receivableId, status])
  @@index([billingCycleId])
}

model PaymentWebhookEvent {
  id              String    @id @default(uuid())
  connectionId    String
  providerEventId String
  eventType       String
  status          String    @default("pending")
  payload         Json
  attempts        Int       @default(0)
  errorMessage    String?   @db.Text
  processedAt     DateTime?
  nextAttemptAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connection PaymentProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, providerEventId])
  @@index([status, createdAt])
  @@index([status, nextAttemptAt])
}

model AdjustmentReview {
  id              String    @id @default(uuid())
  connectionId    String
  saleId          String
  cycleNumber     Int
  indexName       String
  percentage      Decimal   @db.Decimal(8, 4)
  source          String
  reason          String    @db.Text
  status          String    @default("pending")
  createdById     String
  reviewedById    String?
  reviewedAt      DateTime?
  appliedAt       DateTime?
  rejectionReason String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  connection    PaymentProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  sale          Sale                      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy     User                      @relation("AdjustmentReviewCreator", fields: [createdById], references: [id], onDelete: Restrict)
  reviewedBy    User?                     @relation("AdjustmentReviewReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  items         AdjustmentReviewItem[]
  billingCycles BillingCycle[]

  @@unique([connectionId, saleId, cycleNumber])
  @@index([status, createdAt])
}

model AdjustmentReviewItem {
  id                 String   @id @default(uuid())
  adjustmentReviewId String
  receivableId       String
  previousAmount     Decimal  @db.Decimal(15, 2)
  adjustedAmount     Decimal  @db.Decimal(15, 2)
  createdAt          DateTime @default(now())

  adjustmentReview AdjustmentReview @relation(fields: [adjustmentReviewId], references: [id], onDelete: Cascade)
  receivable       Receivable       @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@unique([adjustmentReviewId, receivableId])
  @@index([receivableId])
}

model ReconciliationRun {
  id              String    @id @default(uuid())
  connectionId    String
  status          String    @default("running")
  trigger         String    @default("scheduled")
  checkedCount    Int       @default(0)
  divergenceCount Int       @default(0)
  resolvedCount   Int       @default(0)
  errorMessage    String?   @db.Text
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())

  connection  PaymentProviderConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  divergences ReconciliationDivergence[]

  @@index([connectionId, startedAt])
  @@index([status, startedAt])
}

model ReconciliationDivergence {
  id                      String    @id @default(uuid())
  reconciliationRunId     String
  externalChargeId        String?
  type                    String
  status                  String    @default("detected")
  localValue              Json?
  providerValue           Json?
  resolution              String?   @db.Text
  resolvedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  reconciliationRun ReconciliationRun @relation(fields: [reconciliationRunId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([externalChargeId])
}

model FinancialAuditLog {
  id               String   @id @default(uuid())
  companyId        String
  actorId          String?
  action           String
  entityType       String
  entityId         String
  saleId           String?
  receivableId     String?
  externalChargeId String?
  metadata         Json?
  createdAt        DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([saleId, createdAt])
}

model LotEvent {
  id          String   @id @default(uuid())
  lotId       String
  userId      String?
  type        String
  title       String
  description String?
  notes       String?
  createdAt   DateTime @default(now())

  lot  Lot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([lotId, createdAt])
  @@index([type])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  href      String?
  deduplicationKey String? @unique
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}
