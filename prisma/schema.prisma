// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  logo      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  developments Development[]
}

model Development {
  id        String   @id @default(uuid())
  name      String
  logo      String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company            @relation(fields: [companyId], references: [id])
  blocks       Block[]
  memberships  DevelopmentUser[]
  settings     DevelopmentSettings?
  contractSettings DevelopmentContractSettings?
}

model DevelopmentSettings {
  id                       String   @id @default(uuid())
  developmentId            String   @unique
  reservationValidityDays  Int      @default(7)
  defaultInterestRate      Float    @default(0)
  interestCalculation      String   @default("none")
  correctionIndex          String   @default("none")
  correctionFrequency      String   @default("monthly")
  minDownPaymentPercentage Float    @default(10)
  maxInstallments          Int      @default(120)
  paymentMethods           String   @default("cash,installments")
  allowCustomTerms         Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
}

model DevelopmentContractSettings {
  id                     String   @id @default(uuid())
  developmentId          String   @unique
  sellerName             String   @default("")
  sellerDocument         String   @default("")
  sellerAddress          String   @default("")
  sellerRepresentatives  String   @default("")
  propertyDescription    String   @default("")
  acquisitionDescription String   @default("")
  paymentInstructions    String   @default("")
  jurisdiction           String   @default("")
  additionalClauses      String   @default("") @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  development Development @relation(fields: [developmentId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(uuid())
  name          String
  email         String           @unique
  cpf           String?          @unique
  address       String?
  birthDate     DateTime?
  rg            String?
  emailVerified DateTime?
  image         String?
  profession    String?
  birthplace    String?
  maritalStatus String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  reservations Reservation[]
  sales        Sale[]
  proposals    Proposal[]
  memberships  DevelopmentUser[]
  accounts     Account[]
  sessions     Session[]
  lotEvents    LotEvent[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String               @id @default(uuid())
  name        String               @unique
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  assignments DevelopmentUserRole[]
}

model DevelopmentUser {
  id           String               @id @default(uuid())
  developmentId String
  userId       String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  development  Development          @relation(fields: [developmentId], references: [id])
  user         User                 @relation(fields: [userId], references: [id])
  roles        DevelopmentUserRole[]

  @@unique([developmentId, userId])
}

model DevelopmentUserRole {
  id               String         @id @default(uuid())
  developmentUserId String
  roleId           String
  createdAt        DateTime       @default(now())

  developmentUser  DevelopmentUser @relation(fields: [developmentUserId], references: [id])
  role             Role            @relation(fields: [roleId], references: [id])

  @@unique([developmentUserId, roleId])
}

model Block {
  id           String      @id @default(uuid())
  identifier   String
  developmentId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  development Development? @relation(fields: [developmentId], references: [id])
  lots        Lot[]
}

model Lot {
  id         String   @id @default(uuid())
  identifier String
  blockId    String
  front      Float
  back       Float
  leftSide   Float
  rightSide  Float
  totalArea  Float
  price      Float
  status     String   @default("available")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  block        Block    @relation(fields: [blockId], references: [id])
  reservations Reservation[]
  proposals    Proposal[]
  sale         Sale?    // 👈 one-to-one back relation
  events       LotEvent[]
}

model Reservation {
  id         String   @id @default(uuid())
  userId     String
  lotId      String
  proposal   String
  status     String
  expiresAt  DateTime?
  cancelledAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id])
  lot        Lot    @relation(fields: [lotId], references: [id])
  proposals  Proposal[]
  sale       Sale?  // 👈 if only one sale can reference a reservation

  @@unique([lotId]) // 👈 prevents multiple reservations for the same lot
}

model Proposal {
  id                  String    @id @default(uuid())
  userId              String
  lotId               String
  reservationId       String?
  status              String    @default("draft")
  salePrice           Float
  downPayment         Float
  installmentCount    Int
  installmentValue    Float
  balance             Float
  totalValue          Float
  interestRate        Float     @default(0)
  interestCalculation String    @default("none")
  correctionIndex     String    @default("none")
  correctionFrequency String    @default("monthly")
  firstDueDate        DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  lot         Lot          @relation(fields: [lotId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
}

model Sale {
  id                String     @id @default(uuid())
  userId            String
  lotId             String     @unique
  reservationId     String?    @unique
  installmentCount  Int
  installmentValue  Float
  downPayment       Float
  firstDueDate      DateTime?
  annualAdjustment  Boolean    @default(true)
  totalValue        Float
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  lot         Lot          @relation(fields: [lotId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])
  contract    Contract?
  receivables Receivable[]
}

model Contract {
  id           String    @id @default(uuid())
  saleId       String    @unique
  contractNumber String  @unique
  content      String    @db.Text
  status       String    @default("generated")
  version      Int       @default(1)
  lastRegenerationReason String?
  emailSent    Boolean   @default(false)
  emailSentAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sale Sale @relation(fields: [saleId], references: [id])
  events ContractEvent[]
}

model ContractEvent {
  id          String   @id @default(uuid())
  contractId  String
  userId      String?
  type        String
  title       String
  description String?
  createdAt   DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@index([type])
}

model Receivable {
  id         String    @id @default(uuid())
  saleId     String
  kind       String    @default("installment")
  sequence   Int
  dueDate    DateTime
  amount     Float
  paidAmount Float     @default(0)
  balance    Float
  status     String    @default("pending")
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([saleId, kind, sequence])
  @@index([dueDate])
  @@index([status])
}

model LotEvent {
  id          String   @id @default(uuid())
  lotId       String
  userId      String?
  type        String
  title       String
  description String?
  notes       String?
  createdAt   DateTime @default(now())

  lot  Lot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([lotId, createdAt])
  @@index([type])
}
